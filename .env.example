# ============================================================
# 必填（app 啟動與核心功能所需）
# ============================================================

# PostgreSQL 連線。兩者請勿填一樣：
#   DATABASE_URL = pgbouncer pooled 連線（app runtime 用，帶 ?pgbouncer=true）
#   DIRECT_URL   = 直連 5432（prisma migrate 專用，不可走 pooler）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth v5 session 簽章與站點 URL
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"
# Vercel / production 必須設為 true，否則 NextAuth v5 拒絕 proxy Host header
AUTH_TRUST_HOST="true"

# Upstash Redis（rate limiting）
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# 讀取端防爬限流（GET /api/cards、/api/cards/[id]、/api/sets，選填，未設用寬鬆預設值）。
# 真實 production 閾值請留在 production env，勿寫死進程式碼或 commit 真值。
RL_CARDS_SEARCH_LIMIT="300"
RL_CARDS_SEARCH_WINDOW="1 m"
RL_CARDS_READ_LIMIT="300"
RL_CARDS_READ_WINDOW="1 m"

# 以下兩個密鑰為 lazy 載入：僅在「OAuth 主動連結」「忘記密碼重設」用到時才需要，
# 不影響 app 啟動與核心卡冊功能。本機開發若不碰這兩個流程可先留預設。
# OAuth 主動連結（settings 頁綁定 provider，HMAC-SHA256 簽名 state token 的密鑰）
LINK_STATE_SECRET="your-link-state-secret-here"
# 忘記密碼重設（HMAC-SHA256 stateless token 密鑰，獨立於 LINK_STATE_SECRET）
RESET_TOKEN_SECRET="your-reset-token-secret-here"
# 純 OAuth 使用者補填 email 驗證信（HMAC-SHA256 stateless token 密鑰，獨立於上述兩者）
EMAIL_VERIFY_SECRET="your-email-verify-secret-here"

# ============================================================
# 社群登入 OAuth（選填，不設則僅 Email/密碼登入）
# ============================================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# ============================================================
# Email 寄信（選填）
# ============================================================
# Resend（忘記密碼寄信用）。留為 "test" 即跳過真實寄信，為安全的開箱預設。
RESEND_API_KEY="test"
# 寄件地址（選填）。未設則用預設 'PocketBindr <noreply@send.pocketbindr.app>'。
# Resend 推薦以子網域（send.pocketbindr.app）驗證 DKIM/MX/TXT，非根網域。
EMAIL_FROM="PocketBindr <noreply@send.pocketbindr.app>"
# 缺卡/bug 回報收件信箱（POST /api/report 用）
REPORT_TO_EMAIL="your-email@example.com"

# ============================================================
# Supabase Storage（維護腳本補圖 + runtime 頭像上傳皆用）
# ============================================================
# Supabase Storage service role 為高權限金鑰，勿外洩 / 勿進前端 bundle
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================
# 卡圖 Cloudflare 暖存 proxy（workers/image-proxy/，feat/cloudflare-image-proxy）
# ============================================================
# 官網 hotlink 卡圖（PROXY_HOSTNAMES）改走此 Worker，取代 Vercel /api/proxy-image，egress 免費。
# 公開值（client bundle 會 inline）；未設時 getCardImageUrl 回退 /api/proxy-image（可逆）。
NEXT_PUBLIC_IMAGE_PROXY_ORIGIN="https://images.pocketbindr.app"
