# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# but keep the example template tracked for contributors
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.agents/
.claude/
skills-lock.json
AGENT_TEAM_PROMPT.md

# Playwright
test-results/
playwright-report/

# 爬蟲與維護腳本（本機工具，不進版控）
scripts/

# 腳本產出的暫存檔 / seed 資料
/tmp/
.cache/

# 內部開發文件（保留本機，不公開；對外文件改放根目錄與 .github/）
/docs/
/CLAUDE.md