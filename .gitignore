# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.agents/
.claude/
skills-lock.json
AGENT_TEAM_PROMPT.md

# Playwright
test-results/
playwright-report/

# 官網爬蟲腳本（本機工具，不進版控）
scripts/scrape-*.ts
scripts/scrape-*/
scripts/sync-*.ts
scripts/lib/
# 補圖／稽核／驗證等本機資料工具（依賴 scripts/lib/，不進版控）
scripts/backfill-*.ts
scripts/audit-*.ts
scripts/verify-*.ts
scripts/import-*.ts

# 腳本產出的暫存檔 / seed 資料
/tmp/
scripts/.snapshots/
scripts/data/
.cache/

# Scripts 腳本說明文件
docs/SCRIPTS.md